<?xml version='1.0' encoding='utf-8'?>
<widget id="com.nospam.japan" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Safety Call Japan</name>
    <description>نظام حماية المكالمات المتقدم لليابان</description>
    <author email="dev@safetycall.jp">Zakaria</author>
    
    <content src="index.html" />
    
    <preference name="Fullscreen" value="true" />
    <preference name="StatusBarOverlaysWebview" value="true" />

    <platform name="android">
        <!-- ربط ملف فيرباس إذا كان موجوداً -->
        <resource-file src="google-services.json" target="app/google-services.json" />
        
        <!-- حقن الصلاحيات المطلوبة للحظر مباشرة في الأندرويد -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.READ_PHONE_STATE" />
            <uses-permission android:name="android.permission.READ_CALL_LOG" />
            <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
            <uses-permission android:name="android.permission.BIND_SCREENING_SERVICE" />
        </config-file>
        
        <preference name="AndroidXEnabled" value="true" />
    </platform>

    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
</widget>
