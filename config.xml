<?xml version='1.0' encoding='utf-8'?>
<widget id="com.nospam.japan" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Safety Call Japan</name>
    <description>تطبيق حماية المكالمات المتقدم - إصدار الصلاحيات الكاملة</description>
    <author email="dev@safetycall.jp">Zakaria</author>
    
    <content src="index.html" />
    
    <preference name="AndroidXEnabled" value="true" />

    <platform name="android">
        <!-- ربط ملف Firebase -->
        <resource-file src="google-services.json" target="app/google-services.json" />
        
        <!-- صلاحيات المانيفست الأساسية -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.READ_PHONE_STATE" />
            <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
            <uses-permission android:name="android.permission.READ_CALL_LOG" />
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.BIND_SCREENING_SERVICE" android:permissionFlags="hardRestricted" />
        </config-file>

        <!-- تعريف خدمة فحص المكالمات داخل النظام -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application">
             <service android:name="com.nospam.japan.CallScreeningService"
                 android:permission="android.permission.BIND_SCREENING_SERVICE"
                 android:exported="true">
                 <intent-filter>
                     <action android:name="android.telecom.CallScreeningService" />
                 </intent-filter>
             </service>
        </config-file>
    </platform>

    <access origin="*" />
    <allow-intent href="tel:*" />
</widget>
